"""
动态剧本生成器 — ScriptGenerator (v2 - 稳定版)
成员 B 负责

变更说明 v2:
  改用纯文本 Prompt + JSON 解析策略替代 with_structured_output，
  因为 DeepSeek 对 json_mode 支持不稳定，且 function_calling 对中文复杂
  JSON 嵌套结构解析容易出错。纯文本策略更可靠，且回退逻辑更鲁棒。

功能：
  1. 利用 LLM 纯文本回复 + 正则/手动 JSON 解析生成完整案件剧本
  2. 输出严格符合 case_schema.json 定义的 JSON 结构
  3. 生成后自动写入 SQLite 三张表：case_session + suspect_status + evidence_inventory

使用示例：
    from agents.script_generator import ScriptGenerator
    generator = ScriptGenerator()
    case_data = generator.generate_case("manor")
    generator.save_to_db(case_data, session_id="sess_001")
    
    一步到位：
    sid, case_dict = generator.generate_and_save("steampunk")
"""

import json
import os
import re
import uuid
from typing import Optional

from dotenv import load_dotenv
from pydantic import BaseModel, Field, ValidationError
from langchain_openai import ChatOpenAI

from database.db_helper import DBHelper

load_dotenv()

# ── 用 Pydantic 定义 LLM 输出结构（用于校验而非约束 LLM） ──


class SuspectSchema(BaseModel):
    """嫌疑人数据模型"""
    suspect_id: str = Field(description="嫌疑人 ID: suspect_a / suspect_b / suspect_c")
    name: str = Field(description="嫌疑人全名")
    role: str = Field(description="身份角色，如'庄园的炼金术师'")
    alibi: str = Field(description="不在场证明/公开辩解")
    hidden_truth: str = Field(description="隐藏的真实秘密")
    weakness_item: str = Field(description="弱点证物 ID，如 evidence_1")
    weakness_description: str = Field(description="为何该证物能击破防线")


class EvidenceSchema(BaseModel):
    """证物数据模型"""
    evidence_id: str = Field(description="证物 ID: evidence_1 ~ evidence_5")
    name: str = Field(description="证物名称")
    description: str = Field(description="证物描述")
    location_found: str = Field(description="发现地点")
    category: str = Field(description="类别: weapon / document / forensic / testimony / chemical")
    related_suspect_id: str = Field(description="关联嫌疑人 ID")


class CaseSchema(BaseModel):
    """完整案件数据模型（用于校验输出）"""
    case_name: str = Field(description="案件名称")
    background: str = Field(description="案件背景描述")
    suspects: list[SuspectSchema] = Field(description="嫌疑人列表（2-3人）")
    evidences: list[EvidenceSchema] = Field(description="证物列表（3-5件）")


# ── 剧本生成提示词模板 ──

STYLE_PROMPTS = {
    "manor": (
        "风格：庄园谋杀案（中世纪魔法世界）\n"
        "时代背景：贵族庄园，银月魔法，炼金术与古老诅咒。哥特式悬疑，阴森华丽。"
    ),
    "steampunk": (
        "风格：蒸汽朋克谋杀案\n"
        "时代背景：维多利亚风格蒸汽工业城市，齿轮与蒸汽机，黄铜管道，工厂与机械。黑暗写实，阶级矛盾。"
    ),
    "sci_fi": (
        "风格：废土科幻谋杀案\n"
        "时代背景：未来废土世界，破败的科技都市，全息投影与基因改造，反乌托邦。赛博朋克式的阴冷。"
    ),
}

GENERATION_SYSTEM_PROMPT = """你是"审讯室风云"游戏的谋杀案剧本生成器。

{style_prompt}

请严格按照以下 JSON 结构生成一个完整的谋杀案剧本，只输出 JSON，不要包含任何额外文字、注释或 markdown 代码块标记：

{{
  "case_name": "案件名称（带风格色彩）",
  "background": "案件背景（包含时间、地点、死者、现场状况，100-200字）",
  "suspects": [
    {{
      "suspect_id": "suspect_a",
      "name": "嫌疑人全名",
      "role": "身份角色",
      "alibi": "不在场证明/公开辩解",
      "hidden_truth": "隐藏的真相（解释为何行为可疑但未必是真凶）",
      "weakness_item": "指向该嫌疑人的弱点证物ID，如 evidence_1",
      "weakness_description": "为何该证物能击破防线"
    }}
  ],
  "evidences": [
    {{
      "evidence_id": "evidence_1",
      "name": "证物名称（带描述性）",
      "description": "证物详细描述",
      "location_found": "发现地点",
      "category": "类别：weapon/document/forensic/testimony/chemical 之一",
      "related_suspect_id": "关联的嫌疑人ID"
    }}
  ]
}}

=== 关键规则 ===
1. 生成 3 名嫌疑人（suspect_a ~ suspect_c），每人有独特的 secret/hidden_truth
2. 每个嫌疑人的 weakness_item 必须指向一件真实的证物 ID
3. 生成 4-5 件证物（evidence_1 ~ evidence_5）
4. hidden_truth 要设计得合理——让嫌疑人"可疑但不一定是真凶"
5. 使用虚构的奇幻/科幻名字，不要真实人名地名
6. JSON 必须合法，不要遗漏逗号或括号
"""


def _extract_json(text: str) -> str:
    """
    从 LLM 回复中提取 JSON 字符串。
    处理常见情况：```json包裹、多余文字前缀/后缀、BOM头等。
    """
    text = text.strip()
    # 移除 ```json ... ``` / ``` ... ``` 包裹
    if text.startswith("```"):
        # 移除开头的 ```
        text = re.sub(r"^```(?:json)?\s*\n?", "", text)
        # 移除结尾的 ```
        text = re.sub(r"\n?```\s*$", "", text)
        text = text.strip()

    # 尝试从第一个 { 截取到最后一个 }
    start = text.find("{")
    end = text.rfind("}")
    if start != -1 and end != -1 and end > start:
        text = text[start:end + 1]

    return text


class ScriptGenerator:
    """
    动态剧本生成器。

    使用纯文本 Prompt 策略——让 LLM 以 JSON 格式回复，
    然后手动解析和校验。这种方法兼容性最好，
    适用于 DeepSeek / OpenAI / 各种兼容 API。
    """

    def __init__(
        self,
        model_name: str = "deepseek-chat",
        temperature: float = 0.85,
        max_retries: int = 3,
    ):
        """
        初始化剧本生成器。

        参数:
          model_name: LLM 模型名
          temperature: 生成温度（越高创意越丰富）
          max_retries: 生成失败时的最大重试次数
        """
        api_key = os.getenv("DEEPSEEK_API_KEY") or os.getenv("OPENAI_API_KEY")
        base_url = os.getenv("LLM_BASE_URL", "https://api.deepseek.com/v1")

        self.llm = ChatOpenAI(
            model=model_name,
            temperature=temperature,
            api_key=api_key,
            base_url=base_url,
        )
        self.max_retries = max_retries

    def generate_case(self, style: str = "manor") -> CaseSchema:
        """
        根据风格生成完整案件剧本。

        参数:
          style: 风格名称 — "manor"(庄园) / "steampunk"(蒸汽朋克) / "sci_fi"(废土科幻)

        返回:
          CaseSchema 对象

        异常:
          ValueError: 风格不存在或超过最大重试次数仍无法生成合法 JSON
        """
        if style not in STYLE_PROMPTS:
            valid = list(STYLE_PROMPTS.keys())
            raise ValueError(f"未知风格 '{style}'，可选: {valid}")

        style_prompt = STYLE_PROMPTS[style]
        system_prompt = GENERATION_SYSTEM_PROMPT.format(style_prompt=style_prompt)

        last_error = ""
        for attempt in range(1, self.max_retries + 1):
            try:
                resp = self.llm.invoke([
                    ("system", system_prompt),
                    ("human", f"请生成一个 {style} 风格的谋杀案剧本。只输出 JSON，不要任何其他内容。"),
                ])
                text = resp.content.strip()
                json_str = _extract_json(text)
                case_dict = json.loads(json_str)

                # 用 Pydantic 校验
                case_data = CaseSchema(**case_dict)

                # 额外校验：嫌疑人数和证物数量
                if len(case_data.suspects) < 2:
                    raise ValueError(f"嫌疑人不足2人: {len(case_data.suspects)}")
                if len(case_data.evidences) < 3:
                    raise ValueError(f"证物不足3件: {len(case_data.evidences)}")

                return case_data

            except (json.JSONDecodeError, ValidationError, ValueError) as e:
                last_error = str(e)
                if attempt < self.max_retries:
                    print(f"[ScriptGenerator] 第{attempt}次尝试失败 ({last_error[:80]})，重试...")

        raise RuntimeError(
            f"生成案件失败（已重试{self.max_retries}次）: {last_error}"
        )

    def save_to_db(
        self,
        case_data: CaseSchema,
        session_id: Optional[str] = None,
        action_points: int = 10,
    ) -> str:
        """
        将生成的案件数据写入 SQLite 数据库。

        写入三张表：
          1. case_session     — 会话基本信息和风格
          2. suspect_status   — 每个嫌疑人的状态和 Profile
          3. evidence_inventory — 每件证物记录

        参数:
          case_data: 案件数据（CaseSchema 对象）
          session_id: 会话 ID（不传则自动生成 UUID）
          action_points: 初始行动点数

        返回:
          session_id: 写入后的会话 ID
        """
        case_dict = case_data.model_dump()

        if session_id is None:
            session_id = f"session_{uuid.uuid4().hex[:12]}"

        # 1. 写入 case_session
        DBHelper.create_session(
            session_id=session_id,
            case_style=case_dict.get("style", "manor"),
            case_name=case_dict["case_name"],
            action_points=action_points,
        )

        # 2. 写入嫌疑人
        for suspect in case_dict["suspects"]:
            profile_json = json.dumps(
                {
                    "alibi": suspect["alibi"],
                    "hidden_truth": suspect["hidden_truth"],
                    "weakness_item": suspect["weakness_item"],
                    "weakness_description": suspect["weakness_description"],
                },
                ensure_ascii=False,
            )
            DBHelper.upsert_suspect(
                session_id=session_id,
                suspect_id=suspect["suspect_id"],
                name=suspect["name"],
                role=suspect["role"],
                profile_json=profile_json,
            )

        # 3. 写入证物
        for evidence in case_dict["evidences"]:
            DBHelper.upsert_evidence(
                session_id=session_id,
                evidence_id=evidence["evidence_id"],
                name=evidence["name"],
                description=evidence["description"],
                category=evidence.get("category", "physical"),
                related_suspect_id=evidence.get("related_suspect_id", ""),
            )
        # 更新 case_session 补填风格
        DBHelper.update_session(session_id, case_style=case_dict.get("style", "manor"))

        print(f"[ScriptGenerator] 案件 '{case_dict['case_name']}' 已写入数据库")
        print(f"          会话 ID: {session_id}")
        print(f"          嫌疑人: {len(case_dict['suspects'])} 人")
        print(f"          证物: {len(case_dict['evidences'])} 件")

        return session_id

    def generate_and_save(
        self,
        style: str = "manor",
        session_id: Optional[str] = None,
        action_points: int = 10,
    ) -> tuple[str, dict]:
        """
        生成剧本并直接写入数据库（便捷一步到位）。

        返回:
          (session_id, case_dict)
        """
        case_data = self.generate_case(style)
        case_dict = case_data.model_dump()
        sid = self.save_to_db(case_data, session_id, action_points)
        return sid, case_dict


